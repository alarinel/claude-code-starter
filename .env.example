# =============================================================================
# claude-code-starter -- Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# Lines starting with # are comments. All values shown are defaults.
# =============================================================================

# -----------------------------------------------------------------------------
# Project Identity
# -----------------------------------------------------------------------------
# Display name for your project. Used in terminal titles and logs.
PROJECT_NAME=[YOUR-PROJECT]

# Primary working branch. Agents will stay on this branch.
DEFAULT_BRANCH=main

# -----------------------------------------------------------------------------
# MCP Server
# -----------------------------------------------------------------------------
# URL where your MCP context server is running.
MCP_SERVER_URL=http://localhost:3100

# Name of your MCP server as registered in Claude Code. Must match the key
# used in MCP tool names (e.g., mcp__[this-name]__context).
MCP_SERVER_NAME=[your-mcp-server]

# Port the MCP server listens on.
MCP_SERVER_PORT=3100

# Log level for the MCP server: debug, info, warn, error.
MCP_LOG_LEVEL=info

# -----------------------------------------------------------------------------
# Database (Pro+ Tier)
# -----------------------------------------------------------------------------
# Supported: mysql, postgresql
DB_TYPE=mysql
DB_HOST=localhost
DB_PORT=3306
DB_NAME=[your-database]
DB_USER=[your-db-user]
DB_PASSWORD=[your-db-password]

# Connection pool settings.
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_POOL_IDLE_TIMEOUT=30000

# -----------------------------------------------------------------------------
# Redis (Pro+ Tier)
# -----------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
# Database index (0-15).
REDIS_DB=0

# -----------------------------------------------------------------------------
# Terminal Bridge (Pro+ Tier)
# -----------------------------------------------------------------------------
# URL for the terminal bridge service (manages agent terminals).
TERMINAL_BRIDGE_URL=http://localhost:3200
TERMINAL_BRIDGE_PORT=3200

# Maximum concurrent agent terminals.
TERMINAL_POOL_SIZE=5

# -----------------------------------------------------------------------------
# Backend Application
# -----------------------------------------------------------------------------
# URL of your backend application for health checks and API calls.
BACKEND_URL=http://localhost:8080
BACKEND_PORT=8080

# Build command for the backend (used by build verification step).
BACKEND_BUILD_CMD=npm run build

# -----------------------------------------------------------------------------
# Frontend Application
# -----------------------------------------------------------------------------
# Dev server URL.
FRONTEND_URL=http://localhost:5173
FRONTEND_PORT=5173

# Build command for the frontend.
FRONTEND_BUILD_CMD=npm run build

# -----------------------------------------------------------------------------
# Claude Code CLI
# -----------------------------------------------------------------------------
# Anthropic API key. Required for Claude Code CLI to function.
# Get yours at: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Default Claude model alias. Use: haiku, sonnet, opus (CLI resolves to current versions).
CLAUDE_MODEL=sonnet

# Maximum tokens per response.
CLAUDE_MAX_TOKENS=8192

# -----------------------------------------------------------------------------
# Hooks
# -----------------------------------------------------------------------------
# Enable or disable hook execution. Set to "false" to skip all hooks.
HOOKS_ENABLED=true

# Path to hook scripts directory (relative to project root).
HOOKS_DIR=.claude/hooks

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
# Where hook and agent logs are written.
LOG_DIR=logs

# Log level for hooks: debug, info, warn, error.
LOG_LEVEL=info

# Maximum log file size before rotation (bytes).
LOG_MAX_SIZE=10485760

# Number of rotated log files to retain.
LOG_MAX_FILES=5

# -----------------------------------------------------------------------------
# Session
# -----------------------------------------------------------------------------
# Auto-cleanup temp files older than this (hours). Set to 0 to disable.
SESSION_TEMP_CLEANUP_HOURS=24

# Directory for session temp files (relative to project root).
SESSION_TEMP_DIR=temp
