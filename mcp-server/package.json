{
  "name": "claude-code-starter-mcp-server",
  "version": "1.0.0",
  "description": "Production-grade MCP server boilerplate for Claude Code — includes database, Redis, health checks, circuit breakers, and structured logging.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsx --watch src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "better-sqlite3": "^11.0.0",
    "ioredis": "^5.6.1",
    "knex": "^3.1.0",
    "opossum": "^8.4.2",
    "pino": "^9.6.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "@types/opossum": "^8.1.9",
    "tsx": "^4.19.4",
    "typescript": "^6.0.3"
  },
  "license": "SEE LICENSE IN LICENSE.md"
}
