# Database configuration
DB_CLIENT=better-sqlite3   # Default: zero-config SQLite. Alternatives: mysql2, pg
# DB_CLIENT=mysql2         # Uncomment for MySQL (requires MySQL 8.0+)
# DB_CLIENT=pg             # Uncomment for PostgreSQL (requires PostgreSQL 14+)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=app
DB_POOL_MIN=2
DB_POOL_MAX=10

# Redis configuration
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Logging
LOG_LEVEL=info             # trace, debug, info, warn, error, fatal

# Security
ALLOW_WRITE_QUERIES=false  # Set to true to enable INSERT/UPDATE/DELETE

# Terminal
TERMINAL_TIMEOUT_MS=30000  # Command timeout in milliseconds

# Server identity
MCP_SERVER_NAME=mcp-server
MCP_SERVER_VERSION=1.0.0
